{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "packages": {
    ".": {
      "release-type": "simple",
      "extra-files": [
        {
          "type": "toml",
          "path": "backend/pyproject.toml",
          "jsonpath": "$.project.version"
        },
        {
          "type": "yaml",
          "path": "frontend/pubspec.yaml",
          "jsonpath": "$.version"
        },
        {
          "type": "yaml",
          "path": "vorrat/config.yaml",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
